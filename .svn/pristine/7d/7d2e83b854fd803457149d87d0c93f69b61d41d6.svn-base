#include <sys/types.h>
#include <sys/select.h>
#include <stdio.h>
#include <stdlib.h>
#include <stdarg.h>
#include <string.h>
#include <unistd.h>
#include <time.h>
#include <errno.h>

#define BUFF_SIZE 4096
#define BIN_CALC  "/usr/bin/bc"

#define RP_ATTRIBUTE  0
#define RP_OPEN_QUOT  1
#define RP_CLOSE_QUOT 2
#define RP_EXPR       3
#define RP_EMPTY   1000
#define PR_ERROR   1001

int bcgw_debug = 0;
pid_t app_pid = 0;
char *app_name = "[name not set yet]";

/*
 *  UTIL
 */

void
write_error(char *fmt, ...)
{
    time_t stamp;
    va_list ap;
    int bol;
    char s[BUFF_SIZE];
    char p[BUFF_SIZE];
    char string[BUFF_SIZE];
    char *sp, *a, *b;
    stamp = time(&stamp);
    strcpy(p, asctime(localtime(&stamp)));
    sprintf(p + strlen(p) - 1, " %s [%u] ", basename(app_name), app_pid);
    va_start(ap, fmt);
    vsprintf(s, fmt, ap);  /* XXX */
    va_end(ap);
    bol = 1; /* bol -- begin of line flag */
    for (a=s, sp=string; *a;) {
        if (bol) {
            for (b=p; *b;) *sp++ = *b++;
            bol = 0;
        }
        if (*a == '\n') bol = 1;
        *sp++ = *a++;
    }
    *sp = '\n';
    write(2, string, sp - string + 1);
}

void
write_error_z(char *fmt, char *str, int len) {
    char s[BUFF_SIZE];
    memcpy(s, str, len);
    s[len] = '\0';
    write_error("%s [%s] len=%d", fmt, s, len);
}

void
die(char *reason)
{
    write_error("DIE: %s: %s", reason, strerror( errno ));
    exit(1);
}

/*
 *  RADIUS SIDE
 */

int
eat_attribute(char *req, int len, char **expr, int *expr_len)
{
    int st;
    int s;
    char *ex_ptr = NULL;
    int ex_len = 0;
    for (st = RP_EMPTY, s = 0; s < len && req[s] != '\n'; s++) {
        switch (st) {
	    case RP_EMPTY:
	        st = RP_ATTRIBUTE;
            case RP_ATTRIBUTE:
	        if (s < 3) {
		    if (req[s] != "str"[s]) st = PR_ERROR;
		} else
		    st = RP_OPEN_QUOT;
	        break;
            case RP_OPEN_QUOT: switch(req[s]) {
	                           case '"':
				       ex_ptr = req + s + 1;
				       st = RP_EXPR;
				       break;
				   case ' ': break;
				   case '=': break;
				   default: st = PR_ERROR;
	                       } break;
	    case RP_EXPR: switch(req[s]) {
	                           case '"': st = RP_CLOSE_QUOT; break;
				   default: ex_len++;
                               } break;
	    case RP_CLOSE_QUOT: st = PR_ERROR; break; /* extra chars */
	}
//        printf("RP> [%c] %d\n", req[s], st);
    }
    if (req[s] != '\n') {
        *expr_len = 0; /* do not calulate */
        return 0; /* string incomplite (read more and try agan) */
    }
    if (st != RP_CLOSE_QUOT) {
        *expr_len = 0; /* invalid line; left it */
    } else {
        *expr = ex_ptr;
        *expr_len = ex_len;
    }
    return s + 1;
}

/*
 *  BC SIDE
 */

ssize_t
read_line(int fd, char *buff) /* !!! we suppose that '\n' */
{                             /* !!! cat occur at end of chunk ONLY */
    ssize_t n, len;
    len = 0;
    for (;;) {
        n = read(fd, buff + len, BUFF_SIZE - len);
        if (n <= 0) {
	    die("can not read line from bc");
	}
	len += n;
        if (buff[len-1] = '\n') return len;
	if (len == BUFF_SIZE) {
	    die("buffer full");
	}
    }
}

/*
 *  MAIN LOOP
 */

void
main_loop(int ch_stdin, int ch_stdout, int ch_stderr)
{
    int fd_set_size;
    struct timeval tv;
    fd_set readfds;

    char req[BUFF_SIZE], *expr;
    int req_len, expr_len, req_pr, n, m;
    
    char rep[BUFF_SIZE] = "str=\"";
    char buff[BUFF_SIZE]; /* REMOVE IT */

    fd_set_size = (ch_stdout>ch_stderr?ch_stdout:ch_stderr) + 1;

    tv.tv_sec = 2;
    tv.tv_usec = 500000;

    for (req_len = 0;;) {

//        printf("reading ------------------------------------\n");
//        printf("reading: req_len=%d\n", n, req_len);
        n = read(0, req + req_len, BUFF_SIZE - req_len);
//        printf("reading: n=%d req_len=%d\n", n, req_len);
	if (n <= 0) {
	    die("radius-side pipe closed");
	}
	req_len += n;

        for (;;) {
            n = eat_attribute(req, req_len, &expr, &expr_len);
//	    printf("eat: n=%d\n", n);
            if (n > 1) {
	        if (expr_len > 0) {

                    if (bcgw_debug)
                        write_error_z("pipe to bc", expr, expr_len);

                    write(ch_stdin, expr, expr_len);
                    write(ch_stdin, "\n", 1);

                    FD_ZERO(&readfds);
                    FD_SET(ch_stdout, &readfds);
                    FD_SET(ch_stderr, &readfds);

                    select(fd_set_size, &readfds, NULL, NULL, &tv);
                    
                    if (FD_ISSET(ch_stdout, &readfds)) {
                        m = read_line(ch_stdout, rep+5);
                        rep[m+4] = '"';
                        rep[m+5] = '\n';
                        if (bcgw_debug)
                            write_error_z("pipe to radius", rep, m+5);
		        write(1, rep, m+6);
                    } else if (FD_ISSET(ch_stderr, &readfds)) {
                        m = read_line(ch_stderr, buff);
			write_error_z("EXIT: get on stderr from bc", buff, m-1);
			exit(1);
                    } else {
                        write_error("EXIT: timeout");
		        exit(1);
                    }
		} else {
                    if (bcgw_debug)
                        write_error_z("left line", req, n-1);
		}

            } else if (n == 1) {

                write(1, "int=1\n\n", 7);

            } else { /* n = 0 */

	        break; /* read (append) next chunk and repeat */

            }
	    if (req_len == n) {  /* chunk complete */
	        req_len = 0;
	        break;
	    }
 	    memcpy(req, req + n, req_len - n);
//	    printf("after eat: n=%d\n", n);
	    req_len -= n;
//	    printf("after eat: req_len=%d (--)\n", req_len);
        }
    }
}

/*
 *  MAIN
 */

int
main(int argc, char *argv[])
{
    pid_t pid, childpid;
    int status, died, i;
    int ch_stdin[2];
    int ch_stdout[2];
    int ch_stderr[2];
    char bin_calc[] = BIN_CALC;

    app_pid = getpid();                                                        
    app_name = argv[0];

    for (i=1; i<argc; i++) {
        if (strcmp("-d", argv[i]) == 0) {
	    bcgw_debug = 1;
        } else if (strcmp("-h", argv[i]) == 0) {
            printf("USAGE: bcgw [-d] [-h]\n");
	    return 0;
        } else {
            write_error("Invalid command line parameter %s. exit.", argv[i]);
	    return 1;
        }
    }
						

    if (pipe(ch_stdin) < 0) {
        die("Can not create pipe (ch_stdin)");
    }
    if (pipe(ch_stdout) < 0) {
        die("Can not create pipe (ch_stdout)");
    }
    if (pipe(ch_stderr) < 0) {
        die("Can not create pipe (ch_stdout)");
    }

    pid = fork();
    if (pid < 0) {
        die("Can not fork");
    }
    if (pid == 0) {
        close(ch_stdin[1]);
        close(ch_stdout[0]);
        close(ch_stderr[0]);
        dup2(ch_stdin[0], 0);
        dup2(ch_stdout[1], 1);
        dup2(ch_stderr[1], 2);
        execlp(bin_calc, bin_calc, NULL);
        write_error("ERROR: exec() failed"); /* who listen this scream? */
        close(ch_stdin[0]);
        close(ch_stdout[1]);
        close(ch_stderr[1]);
        return 1;
    } else {
        if (bcgw_debug)
            write_error("child process is created (pid=%d)", pid);
        close(ch_stdin[0]);
        close(ch_stdout[1]);
        close(ch_stderr[1]);
        if (bcgw_debug)
            write_error("enter to mainloop");
        main_loop(ch_stdin[1], ch_stdout[0], ch_stderr[0]);
        if (bcgw_debug)
            write_error("left mainloop");
        close(ch_stderr[0]);
        close(ch_stdout[0]);
        close(ch_stdin[1]);
        if (bcgw_debug)
            write_error("waiting for chaild");
        childpid = waitpid(pid, &status, 0);
        if (bcgw_debug)
            write_error("chaild return status=%d. done.", status);
    }
    return 0;
}

