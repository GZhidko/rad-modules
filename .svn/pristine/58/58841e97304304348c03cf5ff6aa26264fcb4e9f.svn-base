dnl
dnl Configure script pattern for absgw OpenRADIUS module.
dnl
dnl $Log: not supported by cvs2svn $
dnl Revision 1.3  2006/01/24 13:25:27  ilya
dnl 0.0.2
dnl
dnl Revision 1.2  2004/12/20 13:26:51  ilya
dnl path to openradius distro must be configured for build
dnl
dnl Revision 1.1.1.1  2004/12/20 10:46:31  ilya
dnl initial import into CVS
dnl
dnl

dnl Init autoconf
AC_INIT(absgw.c)

dnl Get canonical system information
AC_CANONICAL_SYSTEM

dnl Init automake
AM_INIT_AUTOMAKE(absgw, 0.1.4)
AM_CONFIG_HEADER(config.h)

dnl Checks for programs.
AC_PROG_CC
AC_PROG_CPP
AC_PROG_INSTALL
AC_PROG_MAKE_SET
AM_PROG_LIBTOOL
AC_CHECK_SIZEOF([signed long])

dnl Checks for libraries.
dnl AC_CHECK_LIB(abs_io, abs_v3, abs_msg, abs_ber)

dnl Checks for header files.
AC_HEADER_STDC
AC_CHECK_HEADERS(constants.h platform.h sys/select.h sys/socket.h sysexits.h)

AC_ARG_WITH(openradius-source-dir, [  --with-openradius-source-dir=LOC    OpenRADIUS source-tree dir ])
if test "X${with_openradius_source_dir}" != "X"; then
   OPENRADIUS_INCLUDE_DIR=${with_openradius_source_dir}/common
else
   OPENRADIUS_INCLUDE_DIR=.
fi
if test \! -f "${OPENRADIUS_INCLUDE_DIR}/constants.h"; then
    AC_ERROR(Cannot build without OpenRADIUS source tree)
else
    AC_WARN(Using OpenRADIUS include dir ${OPENRADIUS_INCLUDE_DIR})
fi
AC_SUBST(OPENRADIUS_INCLUDE_DIR)

AC_ARG_WITH(absware-include-dir, [  --with-absware-include-dir=LOC    absware include top dir ])
if test "X${with_absware_include_dir}" != "X"; then
   ABSWARE_INCLUDE_DIR=${with_absware_include_dir}
else
   ABSWARE_INCLUDE_DIR=/usr/local/include/abs
fi
if test \! -f "${ABSWARE_INCLUDE_DIR}/abs/ware.h"; then
   AC_ERROR(Cannot build without absware includes)
fi
AC_SUBST(ABSWARE_INCLUDE_DIR)

dnl Output gathered data
AC_OUTPUT([Makefile])
